    "react": "19.1.0",
    "react-dom": "19.1.0",
    "simple-icons": "^16.26.0",
    "socket.io-client": "^4.8.3",
    "worker-timers": "^8.0.33"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.40",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "^16.0.7",
    "typescript": "^5"
